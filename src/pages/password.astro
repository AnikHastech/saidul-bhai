---
// ============================================================
//  Password Protected — a standalone storefront "lock" splash
//  (own HTML shell, no header/footer/cart). This is a FRONT-END
//  demo gate only: the check runs in the browser, so it is not
//  real access control. For genuine protection, gate at the
//  server/middleware layer.
// ============================================================
import '~/styles/global.css';
import { SITE } from '~/config/site';

export const prerender = false;

// A password gate is an "unauthorized" state — signal it with HTTP 401
// (this matches how Shopify's storefront password page responds).
Astro.response.status = 401;

// Demo passphrase used by the client-side check below.
const DEMO_PASSWORD = 'asmaz';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap"
    />
    <title>Password protected · {SITE.name}</title>
    <meta name="theme-color" content="#050505" />
  </head>

  <body class="pw-body">
    <div class="pw-top">
      <a href="/" class="pw-wordmark">asm<em>az</em>.</a>
      <span class="pw-lockbadge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
        Locked
      </span>
    </div>

    <main class="pw-main">
      <div class="pw-card">
        <span class="pw-eyebrow">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
          Members only
        </span>
        <h1 class="pw-title">Opening <em>soon.</em></h1>
        <p class="pw-sub">
          This store is password protected. Enter the access code to take a look around —
          or check back when we go live.
        </p>

        <form class="pw-form" id="pwForm" autocomplete="off">
          <input class="pw-input" id="pwInput" type="password" name="password" placeholder="Enter password" aria-label="Store password" required />
          <button class="pw-btn" type="submit">Enter</button>
        </form>
        <p class="pw-error" id="pwError" role="alert"></p>

        <p class="pw-hint">Demo access code: <code>{DEMO_PASSWORD}</code></p>
      </div>
    </main>

    <div class="pw-foot">
      {SITE.social.slice(0, 4).map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
      ))}
      <span style="color:var(--muted);">© {year} {SITE.name}</span>
    </div>

    <script is:inline define:vars={{ DEMO_PASSWORD }}>
      // FRONT-END DEMO ONLY — not real access control.
      var form = document.getElementById('pwForm');
      var input = document.getElementById('pwInput');
      var error = document.getElementById('pwError');
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var value = (input.value || '').trim();
        if (value.toLowerCase() === DEMO_PASSWORD.toLowerCase()) {
          error.textContent = '';
          window.location.href = '/';
        } else {
          error.textContent = 'Incorrect password — please try again.';
          input.value = '';
          input.focus();
        }
      });
    </script>
  </body>
</html>
