---
// ============================================================
//  Team member detail — "Cover Story" editorial profile: a dark
//  cinematic hero, a drop-cap story, a full-width pull quote and
//  the rest of the masthead. Data from src/data/team.ts. SSR:
//  looks up by slug, 404s on a miss.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/ui/Button.astro';
import { TEAM, getTeamMember } from '~/data/team';

export const prerender = false;

const { slug } = Astro.params;
const member = getTeamMember(slug!);
if (!member) Astro.response.status = 404;

const idx = member ? TEAM.findIndex((m) => m.slug === member.slug) + 1 : 0;
const no = String(idx).padStart(2, '0');
const [firstName, ...restName] = member ? member.name.split(' ') : [''];
const lastName = restName.join(' ');
const others = member ? TEAM.filter((m) => m.slug !== member.slug).slice(0, 5) : [];

const ig = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2.5" y="2.5" width="19" height="19" rx="5" /><circle cx="12" cy="12" r="4.2" /><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none" /></svg>`;
const x = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.3 8.3L23 22h-6.6l-5.2-6.8L5.2 22H2l7.8-8.9L1.5 2h6.8l4.7 6.2L18.9 2zm-1.2 18h1.8L7.4 3.9H5.5L17.7 20z" /></svg>`;
const li = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.96-1.8-2.96-1.8 0-2.08 1.4-2.08 2.86V21H9z" /></svg>`;

const socials = member
  ? [
      { href: member.social.instagram, label: 'Instagram', svg: ig },
      { href: member.social.x, label: 'X', svg: x },
      { href: member.social.linkedin, label: 'LinkedIn', svg: li },
    ].filter((s) => s.href)
  : [];
---

{
  member ? (
    <BaseLayout title={`${member.name} — ${member.role}`} description={member.tagline} image={member.img}>
      <nav class="wrap tmx-crumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/pages/about">About</a><span class="sep">/</span>
        <span class="cur">{member.name}</span>
      </nav>

      <!-- HERO -->
      <section class="tmx-hero">
        <span class="tmx-watermark" aria-hidden="true">{no}</span>
        <div class="wrap">
          <div class="tmx-hero__in">
            <div class="tmx-portrait">
              <img src={member.img} alt={member.name} onerror="this.style.opacity=0" />
              <span class="tmx-portrait__bar"></span>
            </div>
            <div class="tmx-lead">
              <span class="tmx-kicker"><span class="tmx-kicker__dash"></span> No. {no} · The Masthead</span>
              <h1 class="tmx-name">
                <span class="first">{firstName}</span>{lastName && ' '}<span class="last">{lastName}</span>
              </h1>
              <p class="tmx-role">{member.role}</p>
              <p class="tmx-tagline">{member.tagline}</p>
              {socials.length > 0 && (
                <div class="tmx-social">
                  {socials.map((s) => (
                    <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}><Fragment set:html={s.svg} /></a>
                  ))}
                </div>
              )}
            </div>
          </div>

          <div class="tmx-stats">
            <div class="tmx-stat"><span class="tmx-stat__k">Focus</span><span class="tmx-stat__v">{member.focus}</span></div>
            <div class="tmx-stat"><span class="tmx-stat__k">Based in</span><span class="tmx-stat__v">{member.location}</span></div>
            <div class="tmx-stat"><span class="tmx-stat__k">At asmaz since</span><span class="tmx-stat__v">{member.since}</span></div>
            <div class="tmx-stat"><span class="tmx-stat__k">Role</span><span class="tmx-stat__v">{member.role}</span></div>
          </div>
        </div>
      </section>

      <!-- STORY -->
      <section class="wrap tmx-body">
        <div class="tmx-col">
          <div class="tmx-h"><span class="tmx-h__n">01</span><h2>The Story</h2></div>
          <div class="tmx-story">
            {member.bio.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </section>

      <!-- PULL QUOTE -->
      <section class="tmx-quote">
        <span class="tmx-quote__mark" aria-hidden="true">&ldquo;</span>
        <div class="wrap">
          <div class="tmx-quote__in">
            <p>{member.quote}</p>
            <cite>— {member.name}, {member.role}</cite>
          </div>
        </div>
      </section>

      <!-- EXPERTISE -->
      <section class="wrap tmx-exp">
        <div class="tmx-col">
          <div class="tmx-h"><span class="tmx-h__n">02</span><h2>Expertise</h2></div>
          <div class="tmx-tags">
            {member.expertise.map((t) => <span class="tmx-tag">{t}</span>)}
          </div>
        </div>
      </section>

      <!-- MORE -->
      {others.length > 0 && (
        <section class="wrap tmx-more">
          <div class="tmx-more__head">
            <h2>More from the masthead</h2>
            <a href="/pages/about#abmTeam">View all the team
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          </div>
          <div class="tmx-more__grid">
            {others.map((o) => (
              <a href={`/team/${o.slug}`} class="tmx-mini">
                <img src={o.img} alt={o.name} onerror="this.style.opacity=0" />
                <span class="tmx-mini__o"></span>
                <span class="tmx-mini__meta">
                  <span class="tmx-mini__nm">{o.name}</span>
                  <span class="tmx-mini__rl">{o.role}</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )}
    </BaseLayout>
  ) : (
    <BaseLayout title="Team member not found">
      <div class="wrap empty-state" style="padding-block:96px;">
        <p class="eyebrow kicker">Error 404</p>
        <h2 class="masthead">We couldn’t find that profile</h2>
        <p>That team member may have moved on, or the link is out of date.</p>
        <Button href="/pages/about#abmTeam" variant="news">Meet the team</Button>
      </div>
    </BaseLayout>
  )
}
