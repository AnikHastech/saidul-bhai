---
// ============================================================
//  Footer — dark editorial footer: brand + contact + socials,
//  link columns, trust strip, payment tiles and legal meta.
//  Content from config/site.ts.
// ============================================================
import { SITE } from '~/config/site';
import Logo from '~/components/ui/Logo.astro';
import Icon from '~/components/ui/Icon.astro';
import Badge from '~/components/ui/Badge.astro';

interface Props {
  // The store's real collections — replace the hardcoded "Categories" column.
  categories?: { title: string; url: string }[];
}
const { categories = [] } = Astro.props;

const { contact, footerColumns, valueProps, payments, metaLinks, social } = SITE;

// Resolve each footer column's links: the "Categories" column is driven by
// the store's real collections when available; everything else from config.
type FooterLink = { label: string; href: string; tag?: 'new' | 'deal' };
function columnLinks(col: (typeof footerColumns)[number]): FooterLink[] {
  if (col.title === 'Categories' && categories.length) {
    return categories.slice(0, 8).map((c) => ({ label: c.title, href: c.url }));
  }
  return col.links as unknown as FooterLink[];
}

// Brand-glyph SVG path data for the social row.
const SOCIAL_PATHS: Record<string, string> = {
  instagram:
    'M12 2.16c3.2 0 3.58 0 4.85.07 1.17.05 1.8.25 2.23.41.56.21.96.47 1.38.89.42.42.68.82.89 1.38.16.42.36 1.06.41 2.23.07 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.21.56-.47.96-.89 1.38-.42.42-.82.68-1.38.89-.42.16-1.06.36-2.23.41-1.27.07-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.21-.96-.47-1.38-.89a3.71 3.71 0 0 1-.89-1.38c-.16-.42-.36-1.06-.41-2.23C2.16 15.58 2.16 15.2 2.16 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.21-.56.47-.96.89-1.38.42-.42.82-.68 1.38-.89.42-.16 1.06-.36 2.23-.41C8.42 2.16 8.8 2.16 12 2.16M12 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32M12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8M18.4 4.16a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88',
  x: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  youtube:
    'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8M9.6 15.6V8.4l6.2 3.6z',
  tiktok:
    'M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.83a8.16 8.16 0 0 0 4.77 1.52V6.9a4.85 4.85 0 0 1-1.84-.21z',
  facebook:
    'M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07c0 6 4.39 11 10.13 11.93v-8.44H7.08v-3.5h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.5h-2.8V24C19.61 23.07 24 18.07 24 12.07z',
};
---

<footer class="site-footer">
  <div class="wrap">
    {/* Top: brand + link columns */}
    <div class="footer-top">
      <div class="footer-brand">
        <Logo tone="light" />
        <p class="footer-brand__text">
          The daily destination for tech reviews, curated launches and serious deals — built for
          shoppers who actually read the spec sheet.
        </p>

        <div class="footer-contact">
          <a href={`tel:${contact.phone.replace(/[^+\d]/g, '')}`}>
            <Icon name="phone" size={18} />{contact.phone}
          </a>
          <a href={`mailto:${contact.email}`}>
            <Icon name="mail" size={18} />{contact.email}
          </a>
          <span><Icon name="pin" size={18} />{contact.address}</span>
        </div>

        <div class="footer-socials">
          {
            social.map((s) => (
              <a href={s.href} aria-label={s.label} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                  <path d={SOCIAL_PATHS[s.icon]} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      {
        footerColumns.map((col) => (
          <div class="footer-col">
            <h4 class="footer-col__title">{col.title}</h4>
            <ul>
              {columnLinks(col).map((link) => (
                <li>
                  <a href={link.href}>
                    {link.label}
                    {link.tag === 'new' && <Badge tone="new">NEW</Badge>}
                    {link.tag === 'deal' && <Badge tone="deal">−40%</Badge>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    {/* Mid: trust strip */}
    <div class="footer-mid">
      {
        valueProps.map((vp) => (
          <div class="footer-mid__item">
            <Icon name={vp.icon} size={32} strokeWidth={1.6} />
            <div>
              <h5>{vp.title}</h5>
              <p>{vp.body}</p>
            </div>
          </div>
        ))
      }
    </div>

    {/* Bottom: copy + payments + meta */}
    <div class="footer-bottom">
      <span class="footer-copy">
        Copyright © Asmaz | Designed by <a href="https://hasthemes.com/" target="_blank" rel="noopener noreferrer">HasThemes</a> | Powered by <a href="https://astro.build/" target="_blank" rel="noopener noreferrer">Astro</a>
      </span>
      <div class="footer-pay">
        {
          payments.map((p) => (
            <span class:list={['pay-tile', 'dark' in p && p.dark && 'pay-tile--dark']}>{p.label}</span>
          ))
        }
      </div>
      <div class="footer-meta">
        {metaLinks.map((m) => <a href={m.href}>{m.label}</a>)}
      </div>
    </div>
  </div>
</footer>
