---
// ============================================================
//  FlashDeals — section header with a live countdown + a grid of
//  on-sale product cards. The countdown end + server time are
//  passed in so the timer's first paint matches SSR.
// ============================================================
import ProductGrid from '~/components/product/ProductGrid.astro';
import Countdown from '~/components/react/Countdown.tsx';
import Icon from '~/components/ui/Icon.astro';
import type { ProductCard } from '~/lib/shopify/types';

interface Props {
  products: ProductCard[];
  endsAt: string;
  startMs: number;
}
const { products, endsAt, startMs } = Astro.props;
---

<section class="home-section home-section--mist">
  <div class="wrap">
    <div class="flash__head">
      <div>
        <span class="eyebrow kicker">Limited time</span>
        <h2 class="masthead section-heading__title" style="font-size:clamp(1.75rem,4vw,2.25rem);">
          Flash Deals
        </h2>
      </div>
      <Countdown client:load endsAt={endsAt} startMs={startMs} />
    </div>
    <ProductGrid products={products} />
    <div style="margin-top:32px;text-align:center;">
      <a href="/collections/flash-deals" class="btn btn--news btn--md">
        Shop all deals
        <Icon name="arrowRight" size={16} />
      </a>
    </div>
  </div>
</section>
