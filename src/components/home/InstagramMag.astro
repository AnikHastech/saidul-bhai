---
const POSTS = [
  { img: '/images/insta-1.jpg', likes: '2.4k', comments: '184' },
  { img: '/images/insta-2.jpg', likes: '3.1k', comments: '247' },
  { img: '/images/insta-3.jpg', likes: '1.8k', comments: '96' },
  { img: '/images/insta-4.jpg', likes: '4.7k', comments: '312' },
  { img: '/images/insta-5.jpg', likes: '2.1k', comments: '128' },
  { img: '/images/insta-6.jpg', likes: '5.2k', comments: '423' },
];
---

<section class="section-insta">
  <div class="container">
    <div class="insta-head">
      <span class="label-kicker" style="padding-left:0">Get featured</span>
      <h2>SHOP THE <em>'GRAM.</em></h2>
      <p>Real customers, real setups. Tag your photo with #asmazTech to be featured on our feed and on this page. Click any post to shop the gear.</p>
      <a href="https://instagram.com" target="_blank" rel="noopener" class="insta-handle">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
          <path d="M12 2.16c3.2 0 3.58 0 4.85.07 1.17.05 1.8.25 2.23.41.56.21.96.47 1.38.89.42.42.68.82.89 1.38.16.42.36 1.06.41 2.23C21.84 8.42 21.84 8.8 21.84 12s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.21.56-.47.96-.89 1.38-.42.42-.82.68-1.38.89-.42.16-1.06.36-2.23.41-1.27.07-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.71 3.71 0 0 1-1.38-.89 3.71 3.71 0 0 1-.89-1.38c-.16-.42-.36-1.06-.41-2.23C2.16 15.58 2.16 15.2 2.16 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.21-.56.47-.96.89-1.38.42-.42.82-.68 1.38-.89.42-.16 1.06-.36 2.23-.41C8.42 2.16 8.8 2.16 12 2.16M12 0C8.74 0 8.33 0 7.05.07 5.78.13 4.9.33 4.14.63a5.85 5.85 0 0 0-2.12 1.38A5.85 5.85 0 0 0 .63 4.13c-.3.77-.5 1.65-.56 2.92C0 8.33 0 8.74 0 12s0 3.67.07 4.95c.06 1.27.26 2.15.56 2.92.31.8.73 1.47 1.38 2.12.65.65 1.32 1.07 2.12 1.38.77.3 1.65.5 2.92.56C8.33 24 8.74 24 12 24s3.67 0 4.95-.07c1.27-.06 2.15-.26 2.92-.56a5.85 5.85 0 0 0 2.12-1.38 5.85 5.85 0 0 0 1.38-2.12c.3-.77.5-1.65.56-2.92.07-1.27.07-1.68.07-4.95s0-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.92a5.85 5.85 0 0 0-1.38-2.12A5.85 5.85 0 0 0 19.87.63c-.77-.3-1.65-.5-2.92-.56C15.67 0 15.26 0 12 0z"/>
          <path d="M12 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32M12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8M18.4 4.16a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88"/>
        </svg>
        @asmaz.tech
      </a>
    </div>

    <div class="insta-grid">
      {POSTS.map((post) => (
        <a href="https://instagram.com" target="_blank" rel="noopener" class="insta-post">
          <img src={post.img} alt="Instagram post" loading="lazy" />
          <div class="overlay">
            <span class="stat">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.35-7-10a4.95 4.95 0 0 1 9-2.92A4.95 4.95 0 0 1 19 11c0 5.65-7 10-7 10z"/></svg>
              {post.likes}
            </span>
            <span class="stat">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              {post.comments}
            </span>
          </div>
          <span class="shop-tag">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
