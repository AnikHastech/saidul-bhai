---
// Journal article card — media + meta + title + excerpt.
import type { Article } from '~/lib/shopify/types';

interface Props {
  article: Article;
}
const { article } = Astro.props;

const date = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : null;

// Always show a 2-line summary: use the article's excerpt, falling back to a
// plain-text snippet derived from the body (the CSS clamps it to two lines).
const stripHtml = (html: string) =>
  html.replace(/<[^>]*>/g, ' ').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
const summary = (article.excerpt && article.excerpt.trim())
  ? article.excerpt.trim()
  : stripHtml(article.contentHtml ?? '').slice(0, 240);
---

<a href={`/journal/${article.handle}`} class="article-card" aria-label={article.title}>
  <div class="article-card__media">
    {article.image && <img src={article.image.url} alt={article.image.altText ?? article.title} loading="lazy" />}
  </div>
  <div class="article-card__meta">
    {date && <span>{date}</span>}
    {date && article.author && <span class="sep">·</span>}
    {article.author && <span>{article.author}</span>}
  </div>
  <h3 class="article-card__title">{article.title}</h3>
  {summary && <p class="article-card__excerpt">{summary}</p>}
</a>
