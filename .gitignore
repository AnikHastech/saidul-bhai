# ============================================================
#  Track ONLY the allowlisted items below — everything else in
#  the repo root is ignored by default. The explicit ignores
#  further down are already covered by /*, but kept for clarity.
# ============================================================

# Ignore everything at the repo root…
/*

# …then keep only these files and folders:
!/.github
!/public
!/src
!/.gitignore
!/README.md
!/astro.config.mjs
!/package.json
!/package-lock.json
!/tsconfig.json

# ---- Explicit ignores (redundant under /* — kept for clarity) ----

# build output
dist/

# local QA screenshots
.screenshots/

# generated types
.astro/

# dependencies
node_modules/

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.*

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# vscode
.vscode/

# local Claude Code config (machine-specific permissions/paths)
.claude/
